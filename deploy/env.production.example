# LexForge production environment
# Copy to project root as .env on the server:
#   cp deploy/env.production.example .env
# Then fill secrets (see docs/DEPLOY.md).

# --- Public address ---
# Use IP for now, or replace with domain later (https://your.domain).
PUBLIC_HOST=85.239.40.180
WEB_URL=http://85.239.40.180
# Browser calls same host; nginx proxies /api/ to FastAPI
NEXT_PUBLIC_API_URL=http://85.239.40.180
CORS_ORIGINS=http://85.239.40.180

# --- Application ---
APP_ENV=production
APP_DEBUG=false
APP_SECRET_KEY=CHANGE_ME_GENERATE_WITH_openssl_rand_hex_32
API_HOST=127.0.0.1
API_PORT=8000

# --- PostgreSQL ---
POSTGRES_USER=lexforge
POSTGRES_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD
POSTGRES_DB=lexforge
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://lexforge:CHANGE_ME_STRONG_DB_PASSWORD@127.0.0.1:5432/lexforge
DATABASE_URL_SYNC=postgresql://lexforge:CHANGE_ME_STRONG_DB_PASSWORD@127.0.0.1:5432/lexforge

# --- Redis ---
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_URL=redis://127.0.0.1:6379/0

# --- JWT ---
JWT_SECRET_KEY=CHANGE_ME_GENERATE_WITH_openssl_rand_hex_32
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# --- LLM ---
ROUTERAI_API_KEY=your_routerai_api_key_here
ROUTERAI_BASE_URL=https://routerai.ru/api/v1
ROUTERAI_MODEL=qwen/qwen3-235b-a22b-instruct-2507
LLM_PROVIDER=routerai
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_FALLBACK_MODEL=gpt-4o-mini

# --- Embeddings ---
EMBEDDING_PROVIDER=routerai
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSION=1024

# --- Files ---
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=50

# --- First admin (seed) ---
SEED_ADMIN_EMAIL=admin@lexforge.ru
SEED_ADMIN_PASSWORD=CHANGE_ME_ADMIN_PASSWORD

# --- Deploy paths (used by scripts) ---
LEXFORGE_ROOT=/opt/lexforge
