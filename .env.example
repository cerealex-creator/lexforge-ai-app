# LexForge AI Prototype — скопируйте: cp .env.example .env

# --- Application ---
APP_ENV=development
APP_SECRET_KEY=change-me-to-a-random-64-char-string-in-production
APP_DEBUG=true
API_HOST=0.0.0.0
API_PORT=8000
WEB_URL=http://localhost:3000
# Extra CORS origins for production (comma-separated), optional:
CORS_ORIGINS=

# --- PostgreSQL (pgvector) ---
POSTGRES_USER=lexforge
POSTGRES_PASSWORD=lexforge
POSTGRES_DB=lexforge
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://lexforge:lexforge@localhost:5432/lexforge
DATABASE_URL_SYNC=postgresql://lexforge:lexforge@localhost:5432/lexforge

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# --- JWT ---
JWT_SECRET_KEY=change-me-jwt-secret-min-32-chars-long
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# --- LLM: RouterAI (OpenAI-compatible) ---
ROUTERAI_API_KEY=your_routerai_api_key_here
ROUTERAI_BASE_URL=https://routerai.ru/api/v1
ROUTERAI_MODEL=qwen/qwen3-235b-a22b-instruct-2507

# --- LLM: OpenAI fallback (optional) ---
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_FALLBACK_MODEL=gpt-4o-mini
LLM_PROVIDER=routerai

# --- Embeddings (Phase 4) ---
EMBEDDING_PROVIDER=routerai
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSION=1536

# --- File storage ---
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=50

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:8000

# --- Seed admin ---
SEED_ADMIN_EMAIL=admin@lexforge.ru
SEED_ADMIN_PASSWORD=admin123
